    { "id": "node-4", "type": "integrationNode", "position": { "x": 250, "y": 500 }, "data": { "label": "Create Cardholder", "bpmnType": "integration", "integrationTemplateId": "tpl-stripe-issuing", "operationId": "createCardholder" } },
