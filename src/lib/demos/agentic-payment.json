{
  "name": "Agentic Payment with KYA Guardrails",
  "description": "Verify passport, validate mandate, create payment intent, record spend, check anomaly, then branch on result.",
  "nodes": [
    { "id": "node-1", "type": "startEventNode", "position": { "x": 250, "y": 50 }, "data": { "label": "Start", "bpmnType": "startEvent", "requestBody": [{ "key": "passportId", "type": "string", "required": true, "description": "KYA passport ID" }, { "key": "mandateId", "type": "string", "required": true, "description": "Mandate ID for payment" }] } },
    {
      "id": "node-2",
      "type": "integrationNode",
      "position": { "x": 250, "y": 200 },
      "data": {
        "label": "Verify Passport",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-kya-passport",
        "operationId": "verifyPassport",
        "inputMapping": { "passportId": "{{node-1.passportId}}" },
        "outputSchema": [{ "key": "valid", "type": "boolean" }, { "key": "status", "type": "string" }],
        "stepConfig": { "method": "POST", "path": "/{{passportId}}/verify" }
      }
    },
    { "id": "node-3", "type": "gatewayNode", "position": { "x": 250, "y": 350 }, "data": { "label": "Valid?", "bpmnType": "exclusiveGateway", "conditions": [{ "edgeId": "e-node-3-node-4", "expression": "body.valid === true" }, { "edgeId": "e-node-3-node-err1", "expression": "body.valid !== true" }] } },
    {
      "id": "node-4",
      "type": "integrationNode",
      "position": { "x": 250, "y": 500 },
      "data": {
        "label": "Validate Mandate",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-kya-mandate",
        "operationId": "validateAction",
        "inputMapping": { "mandateId": "{{node-1.mandateId}}", "action": "create_payment", "amountCents": "1000" },
        "outputSchema": [{ "key": "allowed", "type": "boolean" }, { "key": "remaining", "type": "number" }],
        "stepConfig": { "method": "POST", "path": "/mandates/{{mandateId}}/validate", "bodyTemplate": { "action": "{{action}}", "amountCents": "{{amountCents}}" } }
      }
    },
    {
      "id": "node-5",
      "type": "integrationNode",
      "position": { "x": 250, "y": 650 },
      "data": {
        "label": "Create Payment Intent",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-stripe",
        "operationId": "createPaymentIntent",
        "inputMapping": { "amount": "1000", "currency": "usd" },
        "outputSchema": [{ "key": "paymentIntentId", "type": "string" }, { "key": "status", "type": "string" }, { "key": "amount", "type": "number" }, { "key": "currency", "type": "string" }],
        "stepConfig": { "method": "POST", "path": "/payment_intents", "bodyTemplate": { "amount": "{{amount}}", "currency": "{{currency}}" } }
      }
    },
    {
      "id": "node-6",
      "type": "integrationNode",
      "position": { "x": 250, "y": 800 },
      "data": {
        "label": "Record Spend",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-kya-mandate",
        "operationId": "recordSpend",
        "inputMapping": { "mandateId": "{{node-1.mandateId}}", "amountCents": "1000", "action": "payment", "stripeObjectId": "{{node-5.paymentIntentId}}" },
        "outputSchema": [{ "key": "spentCents", "type": "number" }, { "key": "remaining", "type": "number" }, { "key": "status", "type": "string" }],
        "stepConfig": { "method": "POST", "path": "/mandates/{{mandateId}}/spend", "bodyTemplate": { "amountCents": "{{amountCents}}", "action": "{{action}}", "stripeObjectId": "{{stripeObjectId}}" } }
      }
    },
    {
      "id": "node-7",
      "type": "integrationNode",
      "position": { "x": 250, "y": 950 },
      "data": {
        "label": "Check Anomaly",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-kya-monitor",
        "operationId": "checkAnomaly",
        "inputMapping": { "passportId": "{{node-1.passportId}}", "action": "payment", "amountCents": "1000" },
        "outputSchema": [{ "key": "anomalyScore", "type": "number" }, { "key": "flags", "type": "object" }, { "key": "autoRevoked", "type": "boolean" }],
        "stepConfig": { "method": "POST", "path": "/{{passportId}}/anomaly-check", "bodyTemplate": { "action": "{{action}}", "amountCents": "{{amountCents}}" } }
      }
    },
    { "id": "node-8", "type": "gatewayNode", "position": { "x": 250, "y": 1100 }, "data": { "label": "Anomaly?", "bpmnType": "exclusiveGateway", "conditions": [{ "edgeId": "e-node-8-node-9", "expression": "(body.anomalyScore || 0) < 0.7" }, { "edgeId": "e-node-8-node-revoke", "expression": "(body.anomalyScore || 0) >= 0.7" }] } },
    {
      "id": "node-9",
      "type": "integrationNode",
      "position": { "x": 100, "y": 1250 },
      "data": {
        "label": "Log Success",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-kya-monitor",
        "operationId": "logAudit",
        "inputMapping": { "passportId": "{{node-1.passportId}}", "action": "payment_success", "amountCents": "1000", "status": "completed" },
        "outputSchema": [{ "key": "id", "type": "string" }],
        "stepConfig": { "method": "POST", "path": "/{{passportId}}/audit", "bodyTemplate": { "action": "{{action}}", "amountCents": "{{amountCents}}", "status": "{{status}}" } }
      }
    },
    { "id": "node-10", "type": "endEventNode", "position": { "x": 100, "y": 1400 }, "data": { "label": "Success", "bpmnType": "endEvent" } },
    {
      "id": "node-revoke",
      "type": "integrationNode",
      "position": { "x": 400, "y": 1250 },
      "data": {
        "label": "Revoke Agent",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-kya-passport",
        "operationId": "revokePassport",
        "inputMapping": { "passportId": "{{node-1.passportId}}", "reason": "Anomaly threshold exceeded" },
        "outputSchema": [{ "key": "success", "type": "boolean" }],
        "stepConfig": { "method": "POST", "path": "/{{passportId}}/revoke", "bodyTemplate": { "reason": "{{reason}}" } }
      }
    },
    { "id": "node-end-revoke", "type": "endEventNode", "position": { "x": 400, "y": 1400 }, "data": { "label": "Revoked", "bpmnType": "endEvent" } },
    {
      "id": "node-err1",
      "type": "integrationNode",
      "position": { "x": 400, "y": 500 },
      "data": {
        "label": "Log Blocked",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-kya-monitor",
        "operationId": "logAudit",
        "inputMapping": { "passportId": "{{node-1.passportId}}", "action": "payment_blocked", "amountCents": "0", "status": "blocked" },
        "outputSchema": [{ "key": "id", "type": "string" }],
        "stepConfig": { "method": "POST", "path": "/{{passportId}}/audit", "bodyTemplate": { "action": "{{action}}", "amountCents": "{{amountCents}}", "status": "{{status}}" } }
      }
    },
    { "id": "node-err1-end", "type": "endEventNode", "position": { "x": 400, "y": 650 }, "data": { "label": "Error", "bpmnType": "endEvent" } }
  ],
  "edges": [
    { "id": "e-node-1-node-2", "source": "node-1", "target": "node-2", "type": "conditional", "data": {} },
    { "id": "e-node-2-node-3", "source": "node-2", "target": "node-3", "type": "conditional", "data": {} },
    { "id": "e-node-3-node-4", "source": "node-3", "target": "node-4", "type": "conditional", "data": { "label": "Yes" } },
    { "id": "e-node-3-node-err1", "source": "node-3", "target": "node-err1", "type": "conditional", "data": { "label": "No" } },
    { "id": "e-node-4-node-5", "source": "node-4", "target": "node-5", "type": "conditional", "data": {} },
    { "id": "e-node-5-node-6", "source": "node-5", "target": "node-6", "type": "conditional", "data": {} },
    { "id": "e-node-6-node-7", "source": "node-6", "target": "node-7", "type": "conditional", "data": {} },
    { "id": "e-node-7-node-8", "source": "node-7", "target": "node-8", "type": "conditional", "data": {} },
    { "id": "e-node-8-node-9", "source": "node-8", "target": "node-9", "type": "conditional", "data": { "label": "OK" } },
    { "id": "e-node-8-node-revoke", "source": "node-8", "target": "node-revoke", "type": "conditional", "data": { "label": "Anomaly" } },
    { "id": "e-node-9-node-10", "source": "node-9", "target": "node-10", "type": "conditional", "data": {} },
    { "id": "e-node-revoke-end", "source": "node-revoke", "target": "node-end-revoke", "type": "conditional", "data": {} },
    { "id": "e-node-err1-end", "source": "node-err1", "target": "node-err1-end", "type": "conditional", "data": {} }
  ]
}
