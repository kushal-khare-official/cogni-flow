{
  "name": "Agent Capture Payment (PayU)",
  "description": "Verify agent, check balance, deduct balance, and log the audit trail. PayU capture API is called from frontend on success.",
  "nodes": [
    {
      "id": "node-1",
      "type": "startEventNode",
      "position": { "x": 250, "y": 50 },
      "data": {
        "label": "Start",
        "bpmnType": "startEvent",
        "requestBody": [
          { "key": "agentId", "type": "string", "required": true, "description": "Agent passport ID" },
          { "key": "amountCents", "type": "number", "required": true, "description": "Amount to capture in paise" },
          { "key": "bookingReference", "type": "string", "required": false, "description": "Booking reference for audit" }
        ]
      }
    },
    {
      "id": "node-2",
      "type": "integrationNode",
      "position": { "x": 250, "y": 200 },
      "data": {
        "label": "Verify Agent",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-kya-passport",
        "operationId": "verifyPassport",
        "inputMapping": { "passportId": "{{node-1.agentId}}" },
        "outputMapping": { "valid": "body.valid", "status": "body.status" },
        "outputSchema": [
          { "key": "valid", "type": "boolean" },
          { "key": "status", "type": "string" }
        ],
        "stepConfig": { "method": "POST", "path": "/{{passportId}}/verify" }
      }
    },
    {
      "id": "node-3",
      "type": "gatewayNode",
      "position": { "x": 250, "y": 350 },
      "data": {
        "label": "Agent Valid?",
        "bpmnType": "exclusiveGateway",
        "conditions": [
          { "edgeId": "e-node-3-node-4", "expression": "body.valid === true" },
          { "edgeId": "e-node-3-node-err", "expression": "body.valid !== true" }
        ]
      }
    },
    {
      "id": "node-4",
      "type": "integrationNode",
      "position": { "x": 250, "y": 500 },
      "data": {
        "label": "Check Balance",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-custom-code",
        "operationId": "execute",
        "inputMapping": {
          "agentId": "{{node-1.agentId}}",
          "amountCents": "{{node-1.amountCents}}"
        },
        "outputMapping": {
          "sufficient": "sufficient",
          "currentBalance": "currentBalance"
        },
        "outputSchema": [
          { "key": "sufficient", "type": "boolean", "description": "Whether agent has enough balance" },
          { "key": "currentBalance", "type": "number", "description": "Current balance in paise" }
        ],
        "stepConfig": {
          "language": "javascript",
          "code": "const res = await fetch(`${process.env.NEXT_PUBLIC_APP_URL || 'http://localhost:3000'}/api/agents/${input.agentId}`);\nconst agent = await res.json();\nconst currentBalance = agent.balanceCents || 0;\nconst sufficient = currentBalance >= Number(input.amountCents);\nreturn { sufficient, currentBalance };"
        }
      }
    },
    {
      "id": "node-5",
      "type": "gatewayNode",
      "position": { "x": 250, "y": 650 },
      "data": {
        "label": "Sufficient Balance?",
        "bpmnType": "exclusiveGateway",
        "conditions": [
          { "edgeId": "e-node-5-node-6", "expression": "sufficient === true" },
          { "edgeId": "e-node-5-node-insufficient", "expression": "sufficient !== true" }
        ]
      }
    },
    {
      "id": "node-6",
      "type": "integrationNode",
      "position": { "x": 250, "y": 800 },
      "data": {
        "label": "Deduct Balance",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-rest-api",
        "operationId": "request",
        "inputMapping": {
          "agentId": "{{node-1.agentId}}",
          "amountCents": "{{node-1.amountCents}}",
          "bookingReference": "{{node-1.bookingReference}}"
        },
        "outputMapping": {
          "balanceCents": "body.balanceCents",
          "deducted": "body.deducted"
        },
        "outputSchema": [
          { "key": "balanceCents", "type": "number", "description": "Remaining balance after deduction" },
          { "key": "deducted", "type": "number", "description": "Amount deducted" }
        ],
        "stepConfig": {
          "method": "POST",
          "baseUrl": "{{credential.cogniflowUrl}}",
          "path": "/api/agents/{{agentId}}/deduct-balance",
          "bodyTemplate": {
            "amountCents": "{{amountCents}}",
            "bookingReference": "{{bookingReference}}"
          }
        }
      }
    },
    {
      "id": "node-7",
      "type": "integrationNode",
      "position": { "x": 250, "y": 950 },
      "data": {
        "label": "Log Capture Audit",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-kya-monitor",
        "operationId": "logAudit",
        "inputMapping": {
          "passportId": "{{node-1.agentId}}",
          "action": "payment_capture",
          "amountCents": "{{node-1.amountCents}}",
          "status": "completed"
        },
        "outputMapping": { "id": "body.id" },
        "outputSchema": [{ "key": "id", "type": "string", "description": "Audit log ID" }],
        "stepConfig": {
          "method": "POST",
          "path": "/{{passportId}}/audit",
          "bodyTemplate": {
            "action": "{{action}}",
            "amountCents": "{{amountCents}}",
            "status": "{{status}}"
          }
        }
      }
    },
    {
      "id": "node-8",
      "type": "endEventNode",
      "position": { "x": 250, "y": 1100 },
      "data": {
        "label": "Success",
        "bpmnType": "endEvent",
        "responseMode": "sync",
        "outputMapping": {
          "result": {
            "success": true,
            "balanceCents": "{{node-6.balanceCents}}",
            "deducted": "{{node-6.deducted}}",
            "auditId": "{{node-7.id}}"
          }
        }
      }
    },
    {
      "id": "node-err",
      "type": "integrationNode",
      "position": { "x": 500, "y": 350 },
      "data": {
        "label": "Log Agent Invalid",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-kya-monitor",
        "operationId": "logAudit",
        "inputMapping": {
          "passportId": "{{node-1.agentId}}",
          "action": "capture_blocked_invalid_agent",
          "amountCents": "0",
          "status": "blocked"
        },
        "outputMapping": { "id": "body.id" },
        "outputSchema": [{ "key": "id", "type": "string" }],
        "stepConfig": {
          "method": "POST",
          "path": "/{{passportId}}/audit",
          "bodyTemplate": {
            "action": "{{action}}",
            "amountCents": "{{amountCents}}",
            "status": "{{status}}"
          }
        }
      }
    },
    {
      "id": "node-err-end",
      "type": "endEventNode",
      "position": { "x": 500, "y": 500 },
      "data": { "label": "Error - Invalid Agent", "bpmnType": "endEvent" }
    },
    {
      "id": "node-insufficient",
      "type": "integrationNode",
      "position": { "x": 500, "y": 650 },
      "data": {
        "label": "Log Insufficient Balance",
        "bpmnType": "integration",
        "integrationTemplateId": "tpl-kya-monitor",
        "operationId": "logAudit",
        "inputMapping": {
          "passportId": "{{node-1.agentId}}",
          "action": "capture_blocked_insufficient_balance",
          "amountCents": "{{node-1.amountCents}}",
          "status": "blocked"
        },
        "outputMapping": { "id": "body.id" },
        "outputSchema": [{ "key": "id", "type": "string" }],
        "stepConfig": {
          "method": "POST",
          "path": "/{{passportId}}/audit",
          "bodyTemplate": {
            "action": "{{action}}",
            "amountCents": "{{amountCents}}",
            "status": "{{status}}"
          }
        }
      }
    },
    {
      "id": "node-insufficient-end",
      "type": "endEventNode",
      "position": { "x": 500, "y": 800 },
      "data": { "label": "Error - Insufficient Balance", "bpmnType": "endEvent" }
    }
  ],
  "edges": [
    { "id": "e-node-1-node-2", "source": "node-1", "target": "node-2", "type": "conditional", "data": {} },
    { "id": "e-node-2-node-3", "source": "node-2", "target": "node-3", "type": "conditional", "data": {} },
    { "id": "e-node-3-node-4", "source": "node-3", "target": "node-4", "type": "conditional", "data": { "label": "Yes" } },
    { "id": "e-node-3-node-err", "source": "node-3", "target": "node-err", "type": "conditional", "data": { "label": "No" } },
    { "id": "e-node-4-node-5", "source": "node-4", "target": "node-5", "type": "conditional", "data": {} },
    { "id": "e-node-5-node-6", "source": "node-5", "target": "node-6", "type": "conditional", "data": { "label": "Yes" } },
    { "id": "e-node-5-node-insufficient", "source": "node-5", "target": "node-insufficient", "type": "conditional", "data": { "label": "No" } },
    { "id": "e-node-6-node-7", "source": "node-6", "target": "node-7", "type": "conditional", "data": {} },
    { "id": "e-node-7-node-8", "source": "node-7", "target": "node-8", "type": "conditional", "data": {} },
    { "id": "e-node-err-end", "source": "node-err", "target": "node-err-end", "type": "conditional", "data": {} },
    { "id": "e-node-insufficient-end", "source": "node-insufficient", "target": "node-insufficient-end", "type": "conditional", "data": {} }
  ]
}
