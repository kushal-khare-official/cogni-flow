generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Workflow {
  id          String   @id @default(cuid())
  name        String   @default("Untitled Workflow")
  description String   @default("")
  status      String   @default("draft")
  nodes       String   @default("[]")
  edges       String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  validationRuns   ValidationRun[]
  executionRuns    ExecutionRun[]
  webhookEndpoints WebhookEndpoint[]
  schedules        Schedule[]
  mandates         AgentMandate[]
}

model ValidationRun {
  id             String   @id @default(cuid())
  workflowId     String
  inputs         String   @default("[]")
  executionTrace String   @default("[]")
  result         String   @default("pending")
  createdAt      DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model Integration {
  id               String   @id @default(cuid())
  name             String
  icon             String   @default("plug")
  category         String   @default("custom")
  type             String   // "http" | "mcp_tool" | "code" | "webhook" | "kafka" | "stripe_agent"
  description      String   @default("")
  baseConfig       String   @default("{}")
  operations       String   @default("[]")
  credentialSchema String   @default("[]")
  mockConfig       String   @default("{}")
  isBuiltIn        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Credential {
  id             String   @id @default(cuid())
  name           String
  type           String   // "apiKey" | "bearerToken" | "basicAuth" | "oauth2" | "connectionString" | "custom"
  encryptedValue String
  metadata       String   @default("{}")
  workflowId     String?
  createdAt      DateTime @default(now())
}

model ExecutionRun {
  id          String    @id @default(cuid())
  workflowId  String
  trigger     String    @default("manual")
  status      String    @default("pending")
  input       String    @default("{}")
  output      String    @default("{}")
  context     String    @default("{}")
  trace       String    @default("[]")
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model WebhookEndpoint {
  id         String  @id @default(cuid())
  workflowId String
  path       String  @unique
  secret     String  @default("")
  active     Boolean @default(true)

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model Schedule {
  id             String    @id @default(cuid())
  workflowId     String
  cronExpression String
  timezone       String    @default("UTC")
  active         Boolean   @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model McpServerConfig {
  id        String  @id @default(cuid())
  name      String
  transport String  // "stdio" | "http"
  command   String?
  args      String  @default("[]")
  url       String?
  env       String  @default("{}")
}

model AgentPassport {
  id              String    @id @default(cuid())
  name            String
  fingerprint     String    @unique
  modelProvider   String
  modelVersion    String
  creatorName     String
  creatorVerified Boolean   @default(false)
  status          String    @default("active")
  revokedReason   String?
  stripeKeyScope  String    @default("[]")
  authMethod      String    @default("api_key")
  metadata        String    @default("{}")
  issuedAt        DateTime  @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?

  mandates  AgentMandate[]
  auditLogs AgentAuditLog[]
}

model AgentMandate {
  id                 String    @id @default(cuid())
  agentPassportId    String
  workflowId         String?
  description        String
  maxAmountCents     Int       @default(5000)
  maxTotalSpendCents Int       @default(50000)
  spentCents         Int       @default(0)
  allowedActions     String    @default("[]")
  allowedMCCs        String    @default("[]")
  ttlSeconds         Int?
  status             String    @default("active")
  signatureHash      String
  createdAt          DateTime  @default(now())
  expiresAt          DateTime?

  agentPassport AgentPassport @relation(fields: [agentPassportId], references: [id], onDelete: Cascade)
  workflow      Workflow?     @relation(fields: [workflowId], references: [id], onDelete: SetNull)
}

model AgentAuditLog {
  id              String   @id @default(cuid())
  agentPassportId String
  executionRunId  String?
  nodeId          String?
  action          String
  stripeObjectId  String?
  amountCents     Int?
  status          String
  anomalyScore    Float?
  metadata        String   @default("{}")
  createdAt       DateTime @default(now())

  agentPassport AgentPassport @relation(fields: [agentPassportId], references: [id], onDelete: Cascade)
}

model AgenticCheckoutSession {
  id               String   @id @default(cuid())
  status           String   @default("not_ready_for_payment")
  paymentIntentId  String?
  amount           Int      @default(0)
  currency         String   @default("usd")
  lineItems        String   @default("[]")
  totals           String   @default("[]")
  workflowId       String?
  metadata         String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
